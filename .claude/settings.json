{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(cargo:*)",
      "Bash(rustup:*)",
      "Bash(maturin:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(bash tools/codex_review.sh:*)",
      "Bash(bash tools/codex_gen.sh:*)",
      "Bash(codex review:*)"
    ],
    "ask": [
      "Bash(codex exec:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Edit(./assets/generated/**)",
      "Write(./assets/generated/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash tools/post_rust.sh" }
        ]
      }
    ]
  }
}
